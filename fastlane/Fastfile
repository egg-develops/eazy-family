default_platform(:ios)

platform :ios do

  desc "Sync signing certificates and profiles"
  lane :certs do
    match(type: "appstore", readonly: is_ci)
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci if is_ci
    api_key = app_store_connect_api_key(
      key_id: "4H662N6NAJ",
      issuer_id: "7f91d7a9-3944-4240-9843-2fae66b465f4",
      key_filepath: "fastlane/AuthKey_4H662N6NAJ.p8"
    )
    match(type: "appstore", readonly: is_ci)
    increment_build_number(xcodeproj: "ios/App/App.xcodeproj")
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/App/App.xcodeproj",
      team_id: "PU6P37HYB9",
      bundle_identifier: "eazy.family.app",
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore eazy.family.app"
    )
    build_app(
      project: "ios/App/App.xcodeproj",
      scheme: "App",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "eazy.family.app" => "match AppStore eazy.family.app"
        }
      }
    )
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
    telegram_notify(message: "✅ iOS beta uploaded to TestFlight")
  end

  desc "Submit to App Store"
  lane :release do
    match(type: "appstore", readonly: is_ci)
    build_app(
      project: "ios/App/App.xcodeproj",
      scheme: "App",
      export_method: "app-store"
    )
    upload_to_app_store(
      submit_for_review: true,
      automatic_release: false,
      force: true,
      metadata_path: "fastlane/metadata/ios",
      screenshots_path: "fastlane/screenshots/ios"
    )
    telegram_notify(message: "🚀 iOS submitted to App Store review")
  end

end

platform :android do

  desc "Build and upload to Google Play internal track"
  lane :beta do
    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: "android/"
    )
    upload_to_play_store(
      track: "internal",
      aab: "android/app/build/outputs/bundle/release/app-release.aab"
    )
    telegram_notify(message: "✅ Android beta uploaded to Play Store internal track")
  end

  desc "Promote internal to production"
  lane :release do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "production"
    )
    telegram_notify(message: "🚀 Android promoted to Play Store production")
  end

end

# Shared helper — sends message to Telegram on build events
private_lane :telegram_notify do |options|
  token = ENV["TELEGRAM_BOT_TOKEN"]
  chat_id = ENV["TELEGRAM_CHAT_ID"]
  next unless token && chat_id

  sh("curl -s -X POST https://api.telegram.org/bot#{token}/sendMessage \
    -d chat_id=#{chat_id} \
    -d text='#{options[:message]}'")
end
